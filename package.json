{
  "name": "duet-rpc",
  "version": "0.1.2",
  "description": "Bidirectional type-safe RPC over WebSocket",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "rpc",
    "websocket",
    "typescript",
    "bidirectional",
    "ipc",
    "type-safe"
  ],
  "author": "MrLeonardos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrLeonardosMi/duet-rpc.git"
  },
  "bugs": {
    "url": "https://github.com/MrLeonardosMi/duet-rpc/issues"
  },
  "homepage": "https://github.com/MrLeonardosMi/duet-rpc#readme",
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "devalue": "^5.7.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/ws": "^8.18.1",
    "typescript": "~6.0.2",
    "zod": "^4.3.6"
  }
}
